---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import type { FeatureItem } from "~/types";

const features: Array<FeatureItem> = [
  {
    title: "Cursos Personalizados",
    description:
      "Aprende a tu ritmo con cursos diseñados para todos los niveles, desde principiantes hasta expertos en caligrafía y lettering.",
    icon: "mdi:account-heart",
  },
  {
    title: "Técnicas Tradicionales y Modernas",
    description:
      "Domina tanto la caligrafía clásica como las técnicas modernas de lettering, brush lettering y diseño tipográfico.",
    icon: "mdi:palette",
  },
  {
    title: "Práctica Guiada",
    description:
      "Ejercicios paso a paso, plantillas descargables y retroalimentación personalizada para perfeccionar tu técnica.",
    icon: "mdi:hand-pointing-right",
  },
  {
    title: "Comunidad Creativa",
    description:
      "Únete a una comunidad de artistas apasionados, comparte tu progreso y encuentra inspiración en cada trazo.",
    icon: "mdi:account-group",
  },
  {
    title: "Certificación Incluida",
    description:
      "Obtén certificados de finalización que avalen tus nuevas habilidades en lettering y caligrafía artística.",
    icon: "mdi:certificate",
  },
  {
    title: "Soporte Continuo",
    description:
      "Acceso a tutorías personalizadas, sesiones de Q&A en vivo y retroalimentación detallada de tus proyectos.",
    icon: "mdi:help-circle",
  },
];
---

<ContentSection title="¿Por qué elegir nuestros cursos?" id="features">
  <Fragment slot="lead">
    En <span class="font-semibold text-pink-500">Mis Letras Lindas</span> combinamos
    <span class="font-semibold text-purple-500">tradición y modernidad</span> para
    ofrecerte la mejor experiencia de aprendizaje en el mundo del <span
      class="font-semibold text-pink-500">lettering</span
    >.
  </Fragment>
  <ul class="grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      features.map(({ title, description, icon }) => (
        <li class="flex flex-col items-center gap-4 rounded-xl border border-pink-200 bg-gradient-to-br from-pink-50 to-purple-50 p-6 shadow-lg transition-shadow hover:shadow-xl">
          <div class="size-16 rounded-full border-2 border-pink-400 bg-white p-3">
            <Icon name={icon} class="size-full text-pink-500" />
          </div>
          <p class="text-center font-bold text-gray-800 text-xl">{title}</p>
          <p class="text-center leading-relaxed text-gray-600 text-sm">
            {description}
          </p>
        </li>
      ))
    }
  </ul>
</ContentSection>
